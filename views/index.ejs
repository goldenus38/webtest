<% } %>

<!-- 제어판 -->
<div id="control-panel" class="control-panel">
  <div class="cp-toggle" id="cpToggle">&#9881; 제어판</div>
  <div class="cp-body" id="cpBody">
    <div class="cp-section">
      <label class="cp-label">HTTP 상태 코드</label>
      <div class="cp-row">
        <select id="statusSelect">
          <option value="200" <%= statusCode === 200 ? 'selected' : '' %>>200 OK</option>
          <option value="301" <%= statusCode === 301 ? 'selected' : '' %>>301 Moved</option>
          <option value="403" <%= statusCode === 403 ? 'selected' : '' %>>403 Forbidden</option>
          <option value="404" <%= statusCode === 404 ? 'selected' : '' %>>404 Not Found</option>
          <option value="500" <%= statusCode === 500 ? 'selected' : '' %>>500 Internal Error</option>
          <option value="502" <%= statusCode === 502 ? 'selected' : '' %>>502 Bad Gateway</option>
          <option value="503" <%= statusCode === 503 ? 'selected' : '' %>>503 Unavailable</option>
          <option value="custom">커스텀...</option>
        </select>
        <input type="number" id="customStatus" class="cp-custom-input" placeholder="코드" min="100" max="599" style="display:none;">
        <button id="applyStatus" class="cp-btn">적용</button>
      </div>
    </div>
    <div class="cp-section">
      <label class="cp-label">위변조 유형</label>
      <div class="cp-row">
        <select id="defaceSelect">
          <option value="none" <%= defacementType === 'none' ? 'selected' : '' %>>정상 (없음)</option>
          <optgroup label="페이지 교체형 (시각적 탐지)">
            <option value="hacked" <%= defacementType === 'hacked' ? 'selected' : '' %>>Hacked By - 해커 과시형 디페이스먼트</option>
            <option value="hacktivist" <%= defacementType === 'hacktivist' ? 'selected' : '' %>>핵티비스트 - 정치적 메시지 디페이스먼트</option>
            <option value="ransomware" <%= defacementType === 'ransomware' ? 'selected' : '' %>>랜섬웨어 - 파일 암호화 협박</option>
            <option value="phishing" <%= defacementType === 'phishing' ? 'selected' : '' %>>피싱 - 가짜 금융기관 로그인</option>
            <option value="refersec" <%= defacementType === 'refersec' ? 'selected' : '' %>>리퍼섹 - 인도네시아 해커 디페이스먼트</option>
            <option value="malware-download" <%= defacementType === 'malware-download' ? 'selected' : '' %>>악성코드 배포 - 가짜 브라우저 업데이트</option>
            <option value="webshell" <%= defacementType === 'webshell' ? 'selected' : '' %>>웹쉘 - 원격 터미널/파일관리자</option>
            <option value="darkleaks" <%= defacementType === 'darkleaks' ? 'selected' : '' %>>다크리크스 - 데이터 유출 협박 사이트</option>
          </optgroup>
          <optgroup label="소스 삽입형 (HTML 분석 탐지)">
            <option value="seo-spam" <%= defacementType === 'seo-spam' ? 'selected' : '' %>>SEO 스팸 - 숨겨진 스팸 키워드/링크 삽입</option>
            <option value="crypto-mining" <%= defacementType === 'crypto-mining' ? 'selected' : '' %>>암호화폐 채굴 - 숨겨진 채굴 스크립트 삽입</option>
            <option value="redirect" <%= defacementType === 'redirect' ? 'selected' : '' %>>리다이렉트 - 숨겨진 iframe/악성 스크립트 삽입</option>
          </optgroup>
        </select>
        <button id="applyDeface" class="cp-btn">적용</button>
      </div>
      <div class="cp-desc" id="defaceDesc"></div>
    </div>
    <div class="cp-status">
      현재: HTTP <span id="currentStatus"><%= statusCode %></span> | 위변조: <span id="currentDeface"><%= defacementType %></span>
    </div>
  </div>
</div>

<script src="/js/control-panel.js"></script>
</body>
</html>
