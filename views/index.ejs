<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= defacementType === 'none' ? 'TechCorp Solutions - 디지털 혁신 파트너' : 'TechCorp Solutions' %></title>
  <link rel="stylesheet" href="/css/corporate.css">
  <link rel="stylesheet" href="/css/defacements.css">
  <link rel="stylesheet" href="/css/control-panel.css">
</head>
<body>

<% if (defacementType === 'hacked') { %>
<!-- Hacked By 위변조 -->
<div class="defacement defacement-hacked">
  <pre class="skull-art">
     _______________
    /               \
   /                 \
  |   XXXX    XXXX    |
  |   XXXX    XXXX    |
  |   XXX      XXX    |
  \        XX        /
   \      XXXX      /
    \    XXXXXX    /
     \  XXXXXXXX  /
      \__________/
  </pre>
  <h1 class="hacked-title">H4CK3D BY SH4D0W_CR3W</h1>
  <p class="hacked-subtitle">Your security is a joke.</p>
  <p class="hacked-msg">All data has been compromised. We own your system.</p>
  <p class="hacked-sig">Greetz: z3r0c00l | n1ghtm4r3 | ph4nt0m</p>
</div>

<% } else if (defacementType === 'hacktivist') { %>
<!-- 핵티비스트 위변조 -->
<div class="defacement defacement-hacktivist">
  <div class="hacktivist-mask">
    <pre>
    .-""""""""-.
  .'            '.
 /    O      O    \
:           `      :
|                  |
:    \        /    :
 \    '------'    /
  '.            .'
    '-........-'
    </pre>
  </div>
  <h1 class="hacktivist-title">We Are Anonymous</h1>
  <h2 class="hacktivist-subtitle">We Are Legion. We Do Not Forgive. We Do Not Forget.</h2>
  <div class="hacktivist-manifesto">
    <p>This website has been seized in the name of digital freedom.</p>
    <p>The corrupt fear us. The honest support us. The heroic join us.</p>
    <p>Expect us.</p>
  </div>
</div>

<% } else if (defacementType === 'ransomware') { %>
<!-- 랜섬웨어 위변조 -->
<div class="defacement defacement-ransomware">
  <div class="ransomware-icon">&#9888;</div>
  <h1 class="ransomware-title">YOUR FILES HAVE BEEN ENCRYPTED!</h1>
  <div class="ransomware-timer">
    <p>Time remaining to pay:</p>
    <div id="countdown" class="countdown">71:59:59</div>
  </div>
  <div class="ransomware-info">
    <p>All your important files have been encrypted with military-grade AES-256 encryption.</p>
    <p>To recover your files, you must pay <strong>0.5 BTC</strong> to the following address:</p>
    <code class="btc-address">1A1zP1eP5QGefi2DMPTfTL5SLmv7DivfNa</code>
    <p class="ransomware-warning">DO NOT attempt to decrypt files yourself. This will result in permanent data loss.</p>
  </div>
</div>
<script>
(function() {
  let total = 72 * 3600 - 1;
  const el = document.getElementById('countdown');
  if (!el) return;
  setInterval(function() {
    if (total <= 0) return;
    total--;
    const h = String(Math.floor(total / 3600)).padStart(2, '0');
    const m = String(Math.floor((total % 3600) / 60)).padStart(2, '0');
    const s = String(total % 60).padStart(2, '0');
    el.textContent = h + ':' + m + ':' + s;
  }, 1000);
})();
</script>

<% } else if (defacementType === 'phishing') { %>
<!-- 피싱 위변조 -->
<div class="defacement defacement-phishing">
  <div class="phishing-container">
    <div class="phishing-logo">
      <div class="bank-icon">&#127974;</div>
      <h1>KB국민은행</h1>
    </div>
    <div class="phishing-form">
      <h2>보안 인증이 필요합니다</h2>
      <p class="phishing-urgency">고객님의 계좌에서 비정상적인 활동이 감지되었습니다. 본인 확인을 위해 아래 정보를 입력해 주세요.</p>
      <form onsubmit="return false;">
        <label>주민등록번호</label>
        <input type="text" placeholder="앞 6자리" disabled>
        <input type="password" placeholder="뒤 7자리" disabled>
        <label>계좌번호</label>
        <input type="text" placeholder="계좌번호 입력" disabled>
        <label>계좌 비밀번호</label>
        <input type="password" placeholder="비밀번호 입력" disabled>
        <label>보안카드 일련번호</label>
        <input type="text" placeholder="보안카드 번호" disabled>
        <button type="button" class="phishing-btn" disabled>본인 확인</button>
      </form>
      <p class="phishing-footer">&#128274; SSL 보안 연결 | 금융감독원 인증</p>
    </div>
  </div>
</div>

<% } %>

<% if (defacementType === 'seo-spam') { %>
<!-- SEO 스팸 감지 알림 배너 -->
<div class="seo-spam-alert">
  <div class="seo-spam-alert-inner">
    <span class="seo-spam-alert-icon">&#9888;</span>
    <div class="seo-spam-alert-text">
      <strong>SEO Spam Injection Detected!</strong>
      <span>이 페이지에 숨겨진 스팸 콘텐츠가 삽입되었습니다. 아래 소스코드에 보이지 않는 스팸 링크/키워드가 포함되어 있습니다.</span>
    </div>
  </div>
  <div class="seo-spam-preview">
    <div class="seo-spam-preview-title">&#128269; 삽입된 숨겨진 콘텐츠:</div>
    <div class="seo-spam-preview-content">
      <span class="spam-tag">Cheap Viagra Online</span>
      <span class="spam-tag">Best Casino Bonus</span>
      <span class="spam-tag">Free Poker Chips</span>
      <span class="spam-tag">Discount Luxury Watches</span>
      <span class="spam-tag">Replica Designer Bags</span>
      <span class="spam-tag">Weight Loss Pills</span>
      <span class="spam-tag">Online Gambling</span>
      <span class="spam-tag">Buy Medications Online</span>
    </div>
  </div>
</div>
<!-- 실제 숨겨진 스팸 (검색엔진에만 보임) -->
<div class="seo-spam-hidden" aria-hidden="true">
  <h2>Cheap Viagra Online - Buy Now! Best Casino Bonus 2026</h2>
  <p>Buy cheap medications online. Best online casino. Free poker chips. Discount luxury watches. cheap viagra buy online pharmacy discount cialis levitra best price guaranteed overnight shipping free pills bonus casino online gambling slots poker texas holdem blackjack roulette free money no deposit bonus luxury replica watches rolex cartier omega discount designer handbags louis vuitton gucci prada</p>
  <a href="#">Buy Viagra Online</a>
  <a href="#">Best Online Casino</a>
  <a href="#">Cheap Rolex Watches</a>
  <a href="#">Free Casino Bonus</a>
  <a href="#">Discount Pharmacy</a>
  <a href="#">Online Gambling</a>
  <a href="#">Replica Designer Bags</a>
  <a href="#">Weight Loss Pills</a>
</div>
<% } %>

<% if (defacementType === 'crypto-mining') { %>
<!-- 암호화폐 채굴 경고 배너 -->
<div class="crypto-banner">
  <div class="crypto-banner-inner">
    <span class="crypto-icon">&#9888;</span>
    <strong>WARNING: Cryptocurrency mining script detected!</strong>
    <span>이 페이지에서 암호화폐 채굴 스크립트가 실행 중입니다</span>
  </div>
</div>
<!-- 플로팅 CPU 모니터 -->
<div class="crypto-monitor">
  <div class="crypto-monitor-header">&#9874; CryptoMiner v3.2.1</div>
  <div class="crypto-monitor-body">
    <div class="crypto-stat-row">
      <span class="crypto-stat-label">Status</span>
      <span class="crypto-stat-value crypto-active">MINING</span>
    </div>
    <div class="crypto-stat-row">
      <span class="crypto-stat-label">CPU Usage</span>
      <span class="crypto-stat-value"><span id="cpuUsage">87</span>%</span>
    </div>
    <div class="crypto-stat-row">
      <span class="crypto-stat-label">Hash Rate</span>
      <span class="crypto-stat-value"><span id="hashRate">142</span> H/s</span>
    </div>
    <div class="crypto-stat-row">
      <span class="crypto-stat-label">Shares</span>
      <span class="crypto-stat-value"><span id="shares">0</span> / 0</span>
    </div>
    <div class="crypto-progress-bar">
      <div class="crypto-progress-fill" id="cpuBar" style="width:87%"></div>
    </div>
    <div class="crypto-stat-row">
      <span class="crypto-stat-label">Wallet</span>
      <span class="crypto-stat-value crypto-wallet">0x4a8b...f3e2</span>
    </div>
  </div>
</div>
<script>
(function() {
  var cpu = document.getElementById('cpuUsage');
  var bar = document.getElementById('cpuBar');
  var hash = document.getElementById('hashRate');
  var shares = document.getElementById('shares');
  var accepted = 0, total = 0;
  setInterval(function() {
    var v = Math.floor(75 + Math.random() * 23);
    cpu.textContent = v;
    bar.style.width = v + '%';
    hash.textContent = Math.floor(120 + Math.random() * 60);
    if (Math.random() > 0.7) { accepted++; total++; }
    else if (Math.random() > 0.9) { total++; }
    shares.textContent = accepted + ' / ' + total;
  }, 1000);
})();
</script>
<% } %>

<% if (defacementType === 'none' || defacementType === 'seo-spam' || defacementType === 'crypto-mining') { %>
<!-- 정상 기업 사이트 -->
<header class="site-header">
  <div class="container header-inner">
    <div class="logo">
      <span class="logo-icon">&#9670;</span> TechCorp
    </div>
    <nav class="main-nav">
      <a href="#services">서비스</a>
      <a href="#about">회사 소개</a>
